# chr - Chromium development helper
# Usage: chr <subcommand> [options]

_CHR_SCRIPTDIR=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)

CHROMIUMDIR=$(dirname "$_CHR_SCRIPTDIR")
SRCDIR="$CHROMIUMDIR/src"
ORIGINAL_CMDLINE="$*"

# Persistent state, so subcommands share states more smoothly.
_CHR_STATE_FILE="$CHROMIUMDIR/.chr_state"

chr_load_state() {
    # shellcheck source=/dev/null
    test -f "$_CHR_STATE_FILE" && source "$_CHR_STATE_FILE"
}

chr_save_state() {
    local file="$_CHR_STATE_FILE"
    true >"$file"
    for pair in "$@"; do
        echo "$pair" >>"$file"
    done
}

chr_help() {
    cat <<'EOF'
chr - Chromium development helper

Subcommands:
  bootstrap   Initialize submodules and set up for first use
  env         Print environment setup commands for the current shell
  config      Configure and generate build files
  sync        Fetch latest main, rebase a branch stack, and build
  build       Build targets (coming soon)
  run         Run a built binary (coming soon)

Options:
  -h, --help  Show this help

Examples (fish):
  chr env | source                              # set up environment variables
  chr config linux-wayland                      # configure for linux wayland build
  chr sync chromod/chrome-test-base-{0..3}      # sync + rebase + build

Examples (bash/zsh):
  eval "$(chr env --bash)"                      # set up environment variables
  chr sync chromod/my-branch-{0..2} --no-build  # sync + rebase only
EOF
}

chr_env() {
    local format='fish'
    local include_icecc=0

    while [[ $# -gt 0 ]]; do
        case "$1" in
        --bash | --sh) format='bash' ;;
        --icecc) include_icecc=1 ;;
        -h | --help)
            echo "Usage: chr env [--bash|--sh] [--icecc]" >&2
            echo "" >&2
            echo "  --bash, --sh  Print bash/sh-compatible export commands" >&2
            echo "  --icecc       Include icecc-related variables" >&2
            echo "" >&2
            echo "Fish usage:     chr env | source" >&2
            echo "Bash/zsh usage: eval \"\$(chr env --bash)\"" >&2
            return 0
            ;;
        esac
        shift
    done

    # Emit a single exported variable
    emit_var() {
        local key="$1" val="$2"
        if [[ "$format" == 'fish' ]]; then
            printf "set -gx %s '%s'\n" "$key" "$val"
        else
            printf "export %s='%s'\n" "$key" "$val"
        fi
    }

    # Prepend a directory to PATH (skips if dir doesn't exist)
    emit_path_prepend() {
        local dir="$1"
        test -d "$dir" || return 0
        if [[ "$format" == 'fish' ]]; then
            printf "fish_add_path --global --prepend '%s'\n" "$dir"
        else
            printf "export PATH='%s':\$PATH\n" "$dir"
        fi
    }

    # Chrome source root — needed by embedded test server to find cert files
    emit_var CR_SOURCE_ROOT "$SRCDIR"

    # Siso (remote build) credential helper
    emit_var SISO_CREDENTIAL_HELPER "gcloud"

    # Boto config for gsutil (cloud storage auth)
    if [[ -r "$HOME/.boto" ]]; then
        emit_var NO_AUTH_BOTO_CONFIG "$HOME/.boto"
    fi

    # PATH: depot_tools
    emit_path_prepend "$CHROMIUMDIR/tools/depot_tools"

    # PATH: LLVM/clang binaries built with chromium
    emit_path_prepend "$SRCDIR/third_party/llvm-build/Release+Asserts/bin"

    # ICECC (distributed compilation, optional)
    if ((include_icecc)); then
        local icecc_install="${ICECC_INSTALL_DIR:-/usr/lib/icecream}"
        emit_var ICECC_DATA_DIR "$CHROMIUMDIR/icecc"
        emit_var ICECC_INSTALL_DIR "$icecc_install"
        emit_var ICECC_CREATEENV "${ICECC_CREATEENV:-$icecc_install/bin/icecc-create-env}"
        emit_var ICECC_CCWRAPPER "${ICECC_CCWRAPPER:-$icecc_install/libexec/icecc/compilerwrapper}"
    fi
}

chr_bootstrap() {
    echo "### chr bootstrap: initializing chromium submodules"
    if ! command -v git &>/dev/null; then
        echo "### Error: git not found in PATH" >&2
        return 1
    fi
    if git -C "$CHROMIUMDIR" submodule update --init --recursive; then
        echo ""
        echo "### Bootstrap complete. Set up your shell environment:"
        echo "###   fish:     chr env | source"
        echo "###   bash/zsh: eval \"\$(chr env --bash)\""
    else
        echo "### Bootstrap failed!" >&2
        return 1
    fi
}

chr_config() {
    # Alias → "builder_group|builder_name"
    declare -A aliases=(
        ["linux"]="tryserver.chromium.linux|linux-rel"
        ["linux-dbg"]="chromium.linux|Linux Builder (dbg)"
        ["android"]="tryserver.chromium.android|android-arm64-rel"
        ["android-desktop"]="chromium.android.desktop|android-desktop-x64-compile-rel"
        ["cros"]="tryserver.chromium.chromiumos|linux-chromeos-rel"
    )

    local alias_name=''
    local explicit_group=''
    local explicit_builder=''
    local outdir=''
    local -a extra_gn_args=()
    local list_aliases=0
    local list_gn_args=0
    local be_verbose=0
    local update_compdb=0

    while [[ $# -gt 0 ]]; do
        case "$1" in
        -l | --list-aliases) list_aliases=1 ;;
        --list-gn-args) list_gn_args=1 ;;
        -v | --verbose) be_verbose=1 ;;
        -u | --update-compdb) update_compdb=1 ;;
        -o)
            outdir="$2"
            shift
            ;;
        --outdir=*) outdir="${1##--outdir=}" ;;
        --group=*) explicit_group="${1##--group=}" ;;
        --builder=*) explicit_builder="${1##--builder=}" ;;
        --)
            shift
            extra_gn_args=("$@")
            break
            ;;
        -h | --help)
            cat >&2 <<'HELP'
Usage: chr config ALIAS [options] [-- GN_ARG...]
   or: chr config --group=GROUP --builder=BUILDER [options] [-- GN_ARG...]

  -l, --list-aliases       List available build aliases
  --group=GROUP            Builder group (alternative to ALIAS)
  --builder=BUILDER        Builder name (alternative to ALIAS; requires --group)
  -o, --outdir=DIR         Override output directory
  -u, --update-compdb      Regenerate compile_commands.json and update symlink
  -v, --verbose            Show builder group/name with --list-aliases
  -- GN_ARG...             Extra gn args/options passed to gn gen. NOTE: These
                           take precedence over args coming from mb config files. 

  Example:
    chr config linux -- is_debug=true is_component_build=true
    chr config linux -- is_debug=true is_component_build=true
    chr config --group=tryserver.chromium.android --builder=android-x64-rel -- --check
HELP
            return 0
            ;;
        -*)
            echo "chr config: unknown option '$1'" >&2
            return 1
            ;;
        *) alias_name="$1" ;;
        esac
        shift
    done

    # gn build args that are noisy or irrelevant for interactive use
    local -a gn_args_blocklist=(coverage_instrumentation_input_file use_clang_coverage)
    local block_pat
    block_pat="^($(
        IFS='|'
        echo "${gn_args_blocklist[*]}"
    ))[[:space:]]*="

    if ((list_gn_args)); then
        chr_load_state
        local gn="$SRCDIR/buildtools/linux64/gn"
        [[ -x "$gn" && -n "${CHR_CONFIG_OUTDIR:-}" && -d "$SRCDIR/$CHR_CONFIG_OUTDIR" ]] || return 1
        (cd "$SRCDIR" && "$gn" args "$CHR_CONFIG_OUTDIR" --list --short 2>/dev/null) |
            awk -F' = ' '/^[a-zA-Z_]/ && NF>=2 {printf "%s=\t%s\n", $1, $2}' |
            grep -vE "$block_pat"
        return 0
    fi

    if ((list_aliases)); then
        for key in "${!aliases[@]}"; do
            if ((be_verbose)); then
                local val="${aliases[$key]}"
                printf "%-16s  %s / %s\n" "$key" "${val%%|*}" "${val##*|}"
            else
                echo "$key"
            fi
        done | sort
        return 0
    fi

    # Resolve group+builder: either from alias or explicit --group/--builder
    local group='' builder='' resolved_outdir=''
    if [[ -n "$alias_name" && (-n "$explicit_group" || -n "$explicit_builder") ]]; then
        echo "chr config: alias and --group/--builder are mutually exclusive." >&2
        return 1
    elif [[ -n "$alias_name" ]]; then
        local entry="${aliases[$alias_name]}"
        if [[ -z "$entry" ]]; then
            echo "chr config: unknown alias '$alias_name'. Run 'chr config --list-aliases' to see options." >&2
            return 1
        fi
        group="${entry%%|*}"
        builder="${entry##*|}"
        resolved_outdir="${outdir:-out/$alias_name}"
    elif [[ -n "$explicit_group" && -n "$explicit_builder" ]]; then
        group="$explicit_group"
        builder="$explicit_builder"
        if [[ -n "$outdir" ]]; then
            resolved_outdir="$outdir"
        else
            # Sanitize: spaces→-, parens stripped, other non-path chars→_
            local san_group="${explicit_group//[[:space:]]/-}"
            san_group="${san_group//[()]/}"
            local san_builder="${explicit_builder//[[:space:]]/-}"
            san_builder="${san_builder//[()]/}"
            resolved_outdir="out/${san_group}_${san_builder}"
        fi
    elif [[ -n "$explicit_group" || -n "$explicit_builder" ]]; then
        echo "chr config: --group and --builder must be used together." >&2
        return 1
    else
        echo "chr config: alias or --group/--builder required. Run 'chr config --list-aliases' to see aliases." >&2
        return 1
    fi
    local abs_outdir="$SRCDIR/$resolved_outdir"
    local gn="$SRCDIR/buildtools/linux64/gn"

    # Split post-'--' args: --flags go to gn gen, key=value go to args.gn
    local -a gn_opts=()
    local -a gn_build_args=()
    for arg in "${extra_gn_args[@]}"; do
        if [[ "$arg" == --* ]]; then
            gn_opts+=("$arg")
        else
            gn_build_args+=("$arg")
        fi
    done

    # --update-compdb: inject --export-compile-commands into gn gen
    ((update_compdb)) && gn_opts+=("--export-compile-commands")

    local label="${alias_name:-${explicit_group}/${explicit_builder}}"
    echo "### chr config: $label -> $resolved_outdir" >&2
    echo "###   builder: $group / $builder" >&2
    [[ ${#gn_build_args[@]} -gt 0 ]] && echo "###   extra gn args: ${gn_build_args[*]}" >&2
    [[ ${#gn_opts[@]} -gt 0 ]] && echo "###   extra gn opts: ${gn_opts[*]}" >&2

    # Prepend a generation header and strip blocklisted args into a tmpfile first,
    # then announce and atomically replace args.gn.
    local tmpfile
    tmpfile=$(mktemp) || {
        echo "chr config: mktemp failed" >&2
        return 1
    }
    {
        printf '# Generated by: chr %s\n' "$ORIGINAL_CMDLINE"
        printf '# Group/Builder: %s - %s\n\n' "$group" "$builder"
    } >"$tmpfile"

    # Lookup GN args using Chromium's mb (meta-build?) tool, filtering out args in
    # blocklisted args. E.g: coverage_instrumentation_input_file, which causes
    # errors as coverage file do not exit unless in official build servers.
    (cd "$SRCDIR" &&
        python3 tools/mb/mb.py lookup --quiet -m "$group" -b "$builder" |
        grep -vE "$block_pat" >>"$tmpfile") 2>/dev/null ||
        { echo "chr config: mb.py gen failed" >&2; }
    # Command-line GN args go last, so take precedence over build args
    # coming from MB configuration files.
    printf "%s\n" "${gn_build_args[@]}" >>"$tmpfile"

    echo "### Writing GN args to ${abs_outdir}/args.gn" >&2
    mkdir -p "$abs_outdir"
    mv "$tmpfile" "$abs_outdir/args.gn"

    echo "### Running gn gen..." >&2
    (cd "$SRCDIR" && "$gn" gen "${gn_opts[@]}" "$abs_outdir") || return $?

    if ((update_compdb)); then
        local compdb_src="$abs_outdir/compile_commands.json"
        local compdb_link="$SRCDIR/compile_commands.json"
        if [[ -f "$compdb_src" ]]; then
            # Use a relative target so the symlink stays valid if SRCDIR moves
            ln -sfn "$resolved_outdir/compile_commands.json" "$compdb_link"
            echo "### Updated $compdb_link -> $resolved_outdir/compile_commands.json" >&2
        else
            echo "chr config: compile_commands.json not found at $compdb_src" >&2
        fi
    fi

    chr_save_state \
        "CHR_CONFIG_ALIAS=$alias_name" \
        "CHR_CONFIG_BUILDER_GROUP=$group" \
        "CHR_CONFIG_BUILDER=$builder" \
        "CHR_CONFIG_OUTDIR=$resolved_outdir" \
        "CHR_CONFIG_LABEL=$label"

    echo "### State saved -> $_CHR_STATE_FILE" >&2
}

chr_build() {
    echo "chr build: not yet implemented" >&2
    return 1
}

chr_run() {
    echo "chr run: not yet implemented" >&2
    return 1
}

chr_sync() {
    local log_dir log
    local do_build=1
    local top_branch=''

    log_dir="$CHROMIUMDIR/logs"
    while [[ $# -gt 0 ]]; do
        case "$1" in
        --log-dir=*) log_dir="${1##--log-dir=}" ;;
        --log-dir)
            log_dir="$2"
            shift
            ;;
        --no-build) do_build=0 ;;
        --build) do_build=1 ;;
        -h | --help)
            cat >&2 <<'HELP'
Usage: chr sync [BRANCH] [options]

  Refresh local main from origin/main, run gclient sync, then rebase the
  branch stack onto the new main. BRANCH defaults to the current branch in
  src/. The stack (all local branches between origin/main and BRANCH) is
  detected automatically.

  BRANCH            Top of the stack (default: current branch in src/).
  --no-build        Skip builds after rebasing.
  --log-dir=DIR     Log directory (default: ~/projects/chromium/logs).

  Log: <log-dir>/fetch-rebase-build-YYYY-MM-DD.log

  Build targets used:
    out/linux, out/cros              -> chrome browser_tests interactive_ui_tests
    out/android, out/android-desktop -> chrome_public_apk chrome_public_test_apk

  On conflict: resolve manually (git add + git rebase --continue),
  then re-run: chr sync [BRANCH]

  Example:
    chr sync chromod/chrome-test-base-3
HELP
            return 0
            ;;
        -*)
            echo "chr sync: unknown option '$1'" >&2
            return 1
            ;;
        *)
            if [[ -n "$top_branch" ]]; then
                echo "chr sync: too many arguments (expected at most one branch)" >&2
                return 1
            fi
            top_branch="$1"
            ;;
        esac
        shift
    done

    # Default to current branch in src/; on main/detached HEAD, skip rebase
    local skip_rebase=0
    if [[ -z "$top_branch" ]]; then
        top_branch=$(git -C "$SRCDIR" branch --show-current 2>/dev/null)
        if [[ -z "$top_branch" || "$top_branch" == "main" ]]; then
            skip_rebase=1
        fi
    fi

    # Detect the stack: local branches on commits between origin/main and top_branch
    local -a branches=()
    if ! ((skip_rebase)); then
        if ! git -C "$SRCDIR" merge-base origin/main "$top_branch" &>/dev/null; then
            echo "chr sync: $top_branch does not share history with origin/main." >&2
            return 1
        fi
        local commit branch
        while IFS= read -r commit; do
            branch=$(git -C "$SRCDIR" branch --points-at "$commit" \
                --format='%(refname:short)' 2>/dev/null | head -1)
            [[ -n "$branch" ]] && branches+=("$branch")
        done < <(git -C "$SRCDIR" log --reverse --format="%H" \
            "origin/main..${top_branch}" 2>/dev/null)

        if [[ ${#branches[@]} -eq 0 ]]; then
            echo "chr sync: $top_branch has no commits on top of origin/main." >&2
            return 1
        fi
    fi

    mkdir -p "$log_dir"
    log="$log_dir/fetch-rebase-build-$(date +'%Y-%m-%d').log"
    (
        set -e

        echo "### chr sync: $(date)"
        ((skip_rebase)) || echo "### Stack: ${branches[*]}"

        # Refresh local main
        echo "### Refreshing main from origin..."
        if ((skip_rebase)); then
            [[ "$(git -C "$SRCDIR" branch --show-current)" == "main" ]] &&
                git -C "$SRCDIR" checkout --detach -q
        else
            [[ "$(git -C "$SRCDIR" branch --show-current)" == "main" ]] &&
                git -C "$SRCDIR" checkout "${branches[-1]}" -q
        fi
        git -C "$SRCDIR" branch -D main 2>/dev/null || true
        git -C "$SRCDIR" fetch origin main
        git -C "$SRCDIR" checkout FETCH_HEAD -b main
        echo "### main -> $(git -C "$SRCDIR" rev-parse --short HEAD)"

        # Sync dependencies
        echo "### gclient sync -D..."
        (cd "$CHROMIUMDIR" && gclient sync -D)

        # Rebase stack
        if ! ((skip_rebase)); then
            parent="main"
            for branch in "${branches[@]}"; do
                echo "### Rebasing $branch onto $parent..."
                git -C "$SRCDIR" checkout "$branch" -q
                git -C "$SRCDIR" rebase "$parent" || {
                    echo "### Conflict on $branch. Resolve then re-run:"
                    echo "###   git add <files> && git rebase --continue"
                    echo "###   chr sync ${top_branch}"
                    exit 1
                }
                echo "### $branch -> $(git -C "$SRCDIR" rev-parse --short HEAD)"
                parent="$branch"
            done
            git -C "$SRCDIR" checkout "${branches[-1]}" -q
        else
            git -C "$SRCDIR" checkout main -q
        fi

        # Build
        local linux_targets=(chrome browser_tests interactive_ui_tests)
        local android_targets=(chrome_public_apk chrome_public_test_apk)
        local targets=("${linux_targets[@]}")
        if ((do_build)); then
            echo "### Building..."
            for dir in linux cros android android android-desktop; do
                [[ -d "$SRCDIR/out/$dir" ]] || continue
                [[ "$dir" =~ ^android ]] && targets=("${android_targets[@]}")
                echo "### out/$dir: ${targets[*]}"
                autoninja -C "$SRCDIR/out/$dir" "${targets[@]}"
            done
        fi

        echo "### Done: $(date)"

    ) 2>&1 | tee "$log"
    return "${PIPESTATUS[0]}"
}

# --- main dispatch ---
CMD="${1:-help}"
shift 2>/dev/null

case "$CMD" in
bootstrap) chr_bootstrap "$@" ;;
env) chr_env "$@" ;;
config) chr_config "$@" ;;
sync) chr_sync "$@" ;;
build) chr_build "$@" ;;
run) chr_run "$@" ;;
help | -h | --help) chr_help ;;
*)
    echo "chr: unknown subcommand '$CMD'. Run 'chr help' for usage." >&2
    exit 1
    ;;
esac
